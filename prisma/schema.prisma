generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum ScopeType {
  TEAM
  PROJECT
  PRIVATE
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum RecallStatus {
  PENDING
  TRIGGERED
  COMPLETED
  SNOOZED
  CANCELLED
}

enum NodeType {
  PERSON
  PRODUCT
  COMPANY
  CONCEPT
  DATE
  EVENT
  LOCATION
  RULE
  DECISION
  PROCESS
  CUSTOM
}

enum EdgeRelationship {
  IS_A
  HAS
  WORKS_FOR
  CREATED_BY
  RELATED_TO
  PART_OF
  HAPPENS_ON
  LOCATED_IN
  DEPENDS_ON
  CONTRADICTS
  SUPERSEDES
  CUSTOM
}

// ─────────────────────────────────────────────────────────────────────────────
// USERS & TEAMS
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id          String   @id @default(cuid())
  firebaseUid String   @unique @map("firebase_uid")
  email       String   @unique
  displayName String?  @map("display_name")
  avatarUrl   String?  @map("avatar_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  teamMemberships TeamMember[]
  ownedScopes     Scope[]             @relation("ScopeOwner")
  conversations   ScopeConversation[]
  assignedRecalls Recall[]            @relation("RecallAssignee")
  facts           Fact[]
  decisions       Decision[]

  @@map("users")
}

model Team {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  members   TeamMember[]
  scopes    Scope[]
  kgNodes   KgNode[]
  kgEdges   KgEdge[]
  facts     Fact[]
  decisions Decision[]
  documents Document[]
  recalls   Recall[]

  @@map("teams")
}

model TeamMember {
  id       String     @id @default(cuid())
  teamId   String     @map("team_id")
  userId   String     @map("user_id")
  role     MemberRole @default(MEMBER)
  joinedAt DateTime   @default(now()) @map("joined_at")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("team_members")
}

// ─────────────────────────────────────────────────────────────────────────────
// SCOPES (hierarchical knowledge boundaries)
// ─────────────────────────────────────────────────────────────────────────────

model Scope {
  id             String    @id @default(cuid())
  teamId         String    @map("team_id")
  parentScopeId  String?   @map("parent_scope_id")
  type           ScopeType @default(PROJECT)
  name           String
  description    String?
  summary        String?   // AI-generated scope summary
  ownerId        String?   @map("owner_id") // required for PRIVATE scopes
  coupledScopeId String?   @map("coupled_scope_id") // PRIVATE scopes couple to public parent
  activeContext  Json?     @map("active_context") // {tags: string[]} — current context filter
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  team         Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  parent       Scope?              @relation("ScopeHierarchy", fields: [parentScopeId], references: [id])
  children     Scope[]             @relation("ScopeHierarchy")
  owner        User?               @relation("ScopeOwner", fields: [ownerId], references: [id])
  facts        Fact[]
  recalls      Recall[]
  messages     ScopeMessage[]
  conversation ScopeConversation[]

  @@index([teamId])
  @@index([parentScopeId])
  @@map("scopes")
}

model ScopeConversation {
  id      String  @id @default(cuid())
  scopeId String  @map("scope_id")
  userId  String? @map("user_id") // null = shared team/project conversation

  scope    Scope          @relation(fields: [scopeId], references: [id], onDelete: Cascade)
  user     User?          @relation(fields: [userId], references: [id])
  messages ScopeMessage[]

  @@unique([scopeId, userId])
  @@map("scope_conversations")
}

model ScopeMessage {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  scopeId        String   @map("scope_id")
  userId         String?  @map("user_id")
  content        String
  isAi           Boolean  @default(false) @map("is_ai")
  aiCommand      String?  @map("ai_command")
  referencedFacts String[] @map("referenced_facts") // fact IDs mentioned
  replyToId      String?  @map("reply_to_id")
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  conversation ScopeConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  scope        Scope             @relation(fields: [scopeId], references: [id], onDelete: Cascade)
  replyTo      ScopeMessage?     @relation("MessageThread", fields: [replyToId], references: [id])
  replies      ScopeMessage[]    @relation("MessageThread")

  @@index([conversationId])
  @@index([scopeId])
  @@map("scope_messages")
}

// ─────────────────────────────────────────────────────────────────────────────
// KNOWLEDGE GRAPH
// ─────────────────────────────────────────────────────────────────────────────

model KgNode {
  id           String   @id @default(cuid())
  teamId       String   @map("team_id")
  name         String
  type         String   @default("CONCEPT") // NodeType enum value
  description  String?
  // Dual embeddings: v1 (1536-dim legacy), v2 (3072-dim new)
  // Stored as raw SQL columns via migrations — Prisma uses Unsupported for vectors
  parentNodeId String?  @map("parent_node_id") // nested micro-KG support
  scaleLevel   Int      @default(0) @map("scale_level") // 0=root, 1=sub, 2=micro
  properties   Json?    // flexible key/value attributes
  mentionCount Int      @default(1) @map("mention_count")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  parent   KgNode?  @relation("NodeHierarchy", fields: [parentNodeId], references: [id])
  children KgNode[] @relation("NodeHierarchy")
  outEdges KgEdge[] @relation("EdgeSource")
  inEdges  KgEdge[] @relation("EdgeTarget")

  @@index([teamId])
  @@index([parentNodeId])
  @@map("kg_nodes")
}

model KgEdge {
  id                String   @id @default(cuid())
  teamId            String   @map("team_id")
  sourceNodeId      String   @map("source_node_id")
  targetNodeId      String   @map("target_node_id")
  relationship      String   @default("RELATED_TO") // EdgeRelationship enum value
  weight            Float    @default(1.0)
  // THE KEY FEATURE: context conditions gate when this edge is active
  // e.g. [{tag: "on Earth"}, {tag: "daytime"}]
  // Empty/null = always active (no context filter)
  contextConditions Json?    @map("context_conditions")
  sourceType        String?  @map("source_type") // "conversation"|"document"|"manual"
  sourceId          String?  @map("source_id")
  createdAt         DateTime @default(now()) @map("created_at")

  team       Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  sourceNode KgNode @relation("EdgeSource", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode KgNode @relation("EdgeTarget", fields: [targetNodeId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([sourceNodeId])
  @@index([targetNodeId])
  @@map("kg_edges")
}

model KgChunk {
  id            String   @id @default(cuid())
  teamId        String   @map("team_id")
  content       String   // raw text chunk
  sourceType    String   @map("source_type")
  sourceId      String?  @map("source_id")
  sourceTitle   String?  @map("source_title")
  linkedNodeIds String[] @map("linked_node_ids") // KgNode IDs mentioned — stored as array, queried via @> operator
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([teamId])
  @@map("kg_chunks")
}

// ─────────────────────────────────────────────────────────────────────────────
// FACTS & DECISIONS
// ─────────────────────────────────────────────────────────────────────────────

model Fact {
  id              String    @id @default(cuid())
  teamId          String    @map("team_id")
  scopeId         String    @map("scope_id")
  content         String    // the factual statement
  entityType      String?   @map("entity_type")
  entityName      String?   @map("entity_name")
  attribute       String?
  value           String?
  category        String?   // product|manufacturing|marketing|sales|general
  confidenceScore Float     @default(1.0) @map("confidence_score")
  sourceType      String?   @map("source_type") // conversation|document|manual|integration
  sourceQuote     String?   @map("source_quote")
  sourceUrl       String?   @map("source_url")
  contextTags     String[]  @map("context_tags") // active context when this was created
  validFrom       DateTime? @map("valid_from")
  validUntil      DateTime? @map("valid_until")
  supersededBy    String?   @map("superseded_by") // ID of newer fact
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  team  Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  scope Scope @relation(fields: [scopeId], references: [id], onDelete: Cascade)
  createdBy User? @relation(fields: [createdById], references: [id])
  createdById String? @map("created_by_id")

  recalls Recall[]

  @@index([teamId])
  @@index([scopeId])
  @@map("facts")
}

model Decision {
  id           String   @id @default(cuid())
  teamId       String   @map("team_id")
  what         String   // what was decided
  why          String?  // rationale
  alternatives Json?    // [{option, reason_rejected}]
  madeById     String?  @map("made_by_id")
  relatedFacts String[] @map("related_facts") // Fact IDs
  contextTags  String[] @map("context_tags")
  createdAt    DateTime @default(now()) @map("created_at")

  team   Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  madeBy User? @relation(fields: [madeById], references: [id])

  @@index([teamId])
  @@map("decisions")
}

model Document {
  id          String    @id @default(cuid())
  teamId      String    @map("team_id")
  name        String
  fileType    String    @map("file_type")
  sourceUrl   String?   @map("source_url")
  contentText String?   @map("content_text")
  processedAt DateTime? @map("processed_at")
  metadata    Json?
  createdAt   DateTime  @default(now()) @map("created_at")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@map("documents")
}

// ─────────────────────────────────────────────────────────────────────────────
// RECALLS (temporally surfaced knowledge)
// ─────────────────────────────────────────────────────────────────────────────

model Recall {
  id               String       @id @default(cuid())
  teamId           String       @map("team_id")
  scopeId          String       @map("scope_id")
  factId           String       @map("fact_id") // REQUIRED — what knowledge to surface
  title            String?      // optional human label
  triggerType      String       @default("time") @map("trigger_type") // "time" | "event"
  triggerCondition Json         @map("trigger_condition") // {datetime, recurrence} | {pattern}
  status           RecallStatus @default(PENDING)
  triggeredAt      DateTime?    @map("triggered_at")
  completedAt      DateTime?    @map("completed_at")
  snoozedUntil     DateTime?    @map("snoozed_until")
  assignedToId     String?      @map("assigned_to_id")
  createdById      String?      @map("created_by_id")
  createdAt        DateTime     @default(now()) @map("created_at")

  team       Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  scope      Scope @relation(fields: [scopeId], references: [id], onDelete: Cascade)
  fact       Fact  @relation(fields: [factId], references: [id], onDelete: Cascade)
  assignedTo User? @relation("RecallAssignee", fields: [assignedToId], references: [id])

  @@index([teamId])
  @@index([status])
  @@map("recalls")
}
